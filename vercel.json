{
  "buildCommand": "echo 'Static site, no build needed'",
  "outputDirectory": ".",
  "public": true,
  "rewrites": [
    {
      "source": "/robots.txt",
      "destination": "/public/robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/public/sitemap.xml"
    }
  ],
  "redirects": [
    {
      "source": "/:path((?!public).*)*",
      "destination": "https://www.triglpwellness.com/:path*",
      "permanent": true
    }
  ]
}
